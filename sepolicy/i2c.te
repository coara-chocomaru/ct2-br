type i2c_device;
allow mediaserver i2c_device:chr_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow mediaserver i2c_device:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow shell i2c_device:chr_file { getattr };
allow touch_updater i2c_device:chr_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow unconfineddomain i2c_device:chr_file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow unconfineddomain i2c_device:file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow untrusted_app i2c_device:chr_file { getattr };
