allow marvelltel nvm_data_file:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow marvelltel nvm_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
allow marvelltel nvm_device:chr_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow marvelltel nvm_exec:file { read getattr execute execute_no_trans open };
