type nvm;
type nvm_block_device;
type nvm_data_file;
type nvm_device;
type nvm_exec;
type nvm_tmpfs;
allow adbd nvm_block_device:blk_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow adbd nvm_block_device:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow adbd nvm_data_file:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow adbd nvm_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
allow atcmdsrv nvm_device:chr_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow debuggerd nvm:process { ptrace };
allow diag nvm:unix_dgram_socket { ioctl read write create getattr setattr lock append bind connect listen accept getopt setopt shutdown recvfrom sendto recv_msg send_msg name_bind };
allow diag nvm_block_device:blk_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow diag nvm_data_file:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow diag nvm_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
