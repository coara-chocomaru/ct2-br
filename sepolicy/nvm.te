allow eeh nvm_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
allow eeh nvm_device:chr_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow hawk nvm:dir { getattr search };
allow hawk nvm:file { read open };
allow init nvm:process { transition noatsecure siginh rlimitinh };
allow init nvm_data_file:blk_file { relabelto };
allow init nvm_data_file:chr_file { relabelto };
allow init nvm_data_file:dir { relabelto };
allow init nvm_data_file:fifo_file { relabelto };
allow init nvm_data_file:file { relabelto };
allow init nvm_data_file:lnk_file { relabelto };
allow init nvm_data_file:sock_file { relabelto };
allow init nvm_exec:file { read getattr execute open };
allow init nvm_tmpfs:blk_file { relabelto };
allow init nvm_tmpfs:chr_file { relabelto };
allow init nvm_tmpfs:dir { relabelto };
allow init nvm_tmpfs:fifo_file { relabelto };
allow init nvm_tmpfs:file { relabelto };
allow init nvm_tmpfs:lnk_file { relabelto };
allow init nvm_tmpfs:sock_file { relabelto };
allow load_g_cali_data nvm_data_file:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow load_g_cali_data nvm_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
