allow recovery nvm_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
allow recovery nvm_exec:file { read write create getattr setattr relabelfrom relabelto unlink open };
allow setup_fs nvm_block_device:blk_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow shell nvm_block_device:blk_file { getattr };
allow shell nvm_data_file:dir { getattr };
allow shell nvm_device:chr_file { getattr };
allow shell nvm_exec:file { getattr };
allow system_app nvm_data_file:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow system_app nvm_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
allow system_server nvm_data_file:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow unconfineddomain nvm:binder { call set_context_mgr transfer };
allow unconfineddomain nvm_block_device:chr_file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
