allow untrusted_app nvm_block_device:blk_file { getattr };
allow untrusted_app nvm_data_file:dir { read getattr search open };
allow untrusted_app nvm_data_file:file { getattr };
allow untrusted_app nvm_device:chr_file { read getattr };
allow untrusted_app nvm_exec:file { read getattr execute open };
dontaudit init nvm:process { noatsecure };
