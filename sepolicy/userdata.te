type userdata_block_device;
allow recovery userdata_block_device:blk_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow recovery userdata_block_device:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow shell userdata_block_device:blk_file { getattr };
allow system_server userdata_block_device:blk_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow unconfineddomain userdata_block_device:chr_file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow unconfineddomain userdata_block_device:file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow untrusted_app userdata_block_device:blk_file { getattr };
allow vold userdata_block_device:blk_file { ioctl read write create getattr setattr lock append unlink link rename open };
