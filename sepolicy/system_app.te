allow system_app system_app_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
allow system_app system_app_data_file:lnk_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow system_app system_app_device:chr_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow system_app system_app_service:service_manager { add };
allow system_app system_app_tmpfs:file { read write execute };
allow system_server system_app_data_file:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow system_server system_app_data_file:file { ioctl read write create getattr setattr lock append unlink link rename open };
allow unconfineddomain system_app:binder { call set_context_mgr transfer };
allow unconfineddomain system_app_data_file:chr_file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow unconfineddomain system_app_data_file:dir { ioctl read write create getattr setattr lock relabelfrom append unlink link rename execute swapon quotaon mounton add_name remove_name reparent search rmdir open audit_access execmod };
