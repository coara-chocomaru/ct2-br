type infor_device;
allow iml infor_device:chr_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow mediaserver infor_device:chr_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow radio infor_device:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow shell infor_device:chr_file { getattr };
allow unconfineddomain infor_device:chr_file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow unconfineddomain infor_device:file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow untrusted_app infor_device:chr_file { read getattr };
