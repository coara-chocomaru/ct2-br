type dtim_block_device;
allow recovery dtim_block_device:blk_file { ioctl read write create getattr setattr lock append unlink link rename open };
allow recovery dtim_block_device:dir { ioctl read write create getattr setattr unlink link rename add_name remove_name reparent search rmdir open };
allow shell dtim_block_device:blk_file { getattr };
allow unconfineddomain dtim_block_device:chr_file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow unconfineddomain dtim_block_device:file { ioctl read write create getattr setattr lock relabelfrom append unlink link rename swapon quotaon mounton open audit_access };
allow untrusted_app dtim_block_device:blk_file { getattr };
